# Stage 1: Docker CLI (embed docker + compose plugin)
FROM docker:27-cli AS docker-cli

# Stage 2: Go build — compile only the agent binary
FROM golang:1.23-alpine AS go-builder
WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -ldflags="-s -w" -o wireops-agent ./agent/main.go

# Stage 3: Runtime — minimal image with docker CLI
FROM alpine:3.20
RUN apk add --no-cache ca-certificates tzdata

# Embed docker + compose plugin so the agent can run `docker compose up`
COPY --from=docker-cli /usr/local/bin/docker /usr/local/bin/docker
COPY --from=docker-cli /usr/local/libexec/docker/cli-plugins/ /usr/local/libexec/docker/cli-plugins/

WORKDIR /app
COPY --from=go-builder /app/wireops-agent ./wireops-agent

ENTRYPOINT ["/app/wireops-agent"]
