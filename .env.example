# wireops Configuration

# Required: 32-byte key for encrypting credentials (SSH keys, passwords)
# Generate with: openssl rand -hex 32
SECRET_KEY=your-32-byte-secret-key-here

# On first run, visit http://localhost:8090/setup to create the initial administrator account.

# Application URL - Used for CORS, webhooks, and future image URLs
# Format: scheme://host[:port] (no trailing slash or path)
# Examples:
#   - http://localhost:8090 (default)
#   - http://localhost:3000 (when exposing only port 3000 via proxy)
#   - https://wireops.example.com
#   - http://192.168.1.100:8090
APP_URL=http://localhost:8090

# Port to bind the server (default: 8090)
PORT=8090

# PocketBase data directory (default: ./pb_data)
PB_DATA_DIR=./pb_data

# Directory for cloned repositories (default: ./repos)
REPOS_WORKSPACE=./repos

# --- OIDC/SSO Configuration (Optional) ---
# Enable SSO login by providing OIDC provider details.
# All URLs must use HTTPS in production.

# OIDC_CLIENT_ID=your-client-id
# OIDC_CLIENT_SECRET=your-client-secret
# OIDC_AUTH_URL=https://your-idp.example.com/oauth2/authorize
# OIDC_TOKEN_URL=https://your-idp.example.com/oauth2/token
# OIDC_USER_INFO_URL=https://your-idp.example.com/oauth2/userinfo
# OIDC_DISPLAY_NAME=SSO
# OIDC_REQUIRE_EMAIL_VERIFIED=false # True by default
# When "false", allows SSO logins where the identity provider did not verify the email.
# Default: true (rejects unverified emails)

# --- Dev Environment Variables ---
# Set to 'true' to also start a local worker during 'make dev'
START_WORKER=false

# If START_WORKER is true, or if you want the worker to bootstrap automatically
# during dev, you can provide the token generated from the server UI.
BOOTSTRAP_TOKEN=

# --- TLS Configuration (Optional) ---
# Enable native TLS on the worker server port (:8443) so that workers can
# connect directly via HTTPS/WSS without routing through a reverse proxy.
# This is especially useful when wireops itself manages a Traefik stack: if
# Traefik goes down, workers can still reconnect directly.
#
# Set TLS_ENABLED=true to activate TLS on the worker server.
# TLS_ENABLED=false

# Public hostname or IP address of this server, added to the Subject Alternative
# Names (SAN) of the auto-generated self-signed certificate. Required when
# workers run on a different host and you want them to verify the certificate
# without setting WORKER_TLS_SKIP_VERIFY=true.
# Accepts a bare domain (e.g. wireops.example.com) or an IP (e.g. 192.168.1.10).
# Ignored when TLS_CERT_FILE / TLS_KEY_FILE are set.
# SERVER_DOMAIN=wireops.example.com

# Provide PEM-encoded certificate and private key files.
# If left empty while TLS_ENABLED=true, a self-signed certificate is generated
# automatically on each startup (workers must set WORKER_TLS_SKIP_VERIFY=true).
# TLS_CERT_FILE=/path/to/cert.pem
# TLS_KEY_FILE=/path/to/key.pem

# Directory where the auto-generated self-signed certificate is stored.
# When set, the cert/key pair (tls-cert.pem + tls-key.pem) is reused across
# restarts, so workers keep trusting the same certificate without reconnecting.
# Ignored when TLS_CERT_FILE / TLS_KEY_FILE are set.
# TLS_DATA_DIR=./pb_data/tls

# Override the worker server listen port (default: 8443).
# TLS_WORKER_PORT=8443

# --- Worker TLS Configuration ---
# Set WORKER_TLS_SKIP_VERIFY=true when the server uses a self-signed
# certificate. WARNING: do NOT enable this in production with trusted certificates.
# WORKER_TLS_SKIP_VERIFY=false
