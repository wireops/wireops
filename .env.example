# wireops Configuration

# Required: 32-byte key for encrypting credentials (SSH keys, passwords)
# Generate with: openssl rand -hex 32
SECRET_KEY=your-32-byte-secret-key-here

# On first run, visit http://localhost:8090/setup to create the initial administrator account.

# Application URL - Used for CORS, webhooks, and future image URLs
# Format: scheme://host[:port] (no trailing slash or path)
# Examples:
#   - http://localhost:8090 (default)
#   - http://localhost:3000 (when exposing only port 3000 via proxy)
#   - https://wireops.example.com
#   - http://192.168.1.100:8090
APP_URL=http://localhost:8090

# Port to bind the server (default: 8090)
PORT=8090

# PocketBase data directory (default: ./pb_data)
PB_DATA_DIR=./pb_data

# Directory for cloned repositories (default: ./repos)
REPOS_WORKSPACE=./repos

# --- OIDC/SSO Configuration (Optional) ---
# Enable SSO login by providing OIDC provider details.
# All URLs must use HTTPS in production.

# OIDC_CLIENT_ID=your-client-id
# OIDC_CLIENT_SECRET=your-client-secret
# OIDC_AUTH_URL=https://your-idp.example.com/oauth2/authorize
# OIDC_TOKEN_URL=https://your-idp.example.com/oauth2/token
# OIDC_USER_INFO_URL=https://your-idp.example.com/oauth2/userinfo
# OIDC_DISPLAY_NAME=SSO

# When "true", reject SSO logins where the identity provider did not verify the email.
# Default: false (allows unverified emails)
# OIDC_REQUIRE_EMAIL_VERIFIED=false

# --- Dev Environment Variables ---
# Set to 'true' to also start a local worker during 'make dev'
START_WORKER=false

# If START_WORKER is true, or if you want the worker to bootstrap automatically
# during dev, you can provide the token generated from the server UI.
WIREOPS_BOOTSTRAP_TOKEN=
