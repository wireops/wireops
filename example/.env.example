# --------------------------------------------------------------------
#                              Server
# --------------------------------------------------------------------

# Required — generate with: openssl rand -hex 32
SECRET_KEY=change_me_32_chars_minimum

# Bootstrap token (required for first admin setup)
# On first run, visit the server URL at /setup to create the initial administrator account.
BOOTSTRAP_TOKEN=change_me

# Public URL of the server (used for CORS and webhooks)
APP_URL=http://localhost:8090

# Host port to expose for the wireops web UI
PORT=8090

# Where PocketBase stores its data (databases, migrations)
PB_DATA_DIR=/data/pb_data

# --------------------------------------------------------------------
#                              Worker
# --------------------------------------------------------------------

# Worker connection URL (the worker reaches the server via the Docker service name on port 8443)
WIREOPS_SERVER=http://wireops:8443

# Registration / authorization token generated from the wireops admin panel
WORKER_TOKEN=

# Optional: override the name shown in the wireops UI
WORKER_HOSTNAME=worker-01

# Host port to expose for the mTLS worker channel
TLS_WORKER_PORT=8443

# Where git repositories are cloned
REPOS_WORKSPACE=/data/repos
