# Stage 1: Docker CLI (embed docker + compose plugin)
FROM docker:27-cli AS docker-cli

# Stage 2: Go build — compile only the worker binary
FROM golang:1.23-alpine AS go-builder
WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download
COPY worker/ ./worker/
COPY internal/ ./internal/
RUN CGO_ENABLED=0 GOOS=linux go build -ldflags="-s -w" -o wireops-worker ./worker/main.go

# Stage 3: Runtime — minimal image with docker CLI
FROM alpine:3.20
RUN apk add --no-cache ca-certificates tzdata \
    && addgroup -g 1000 appgroup \
    && adduser -u 1000 -G appgroup -s /bin/sh -D appuser

# Embed docker + compose plugin so the worker can run `docker compose up`
COPY --from=docker-cli /usr/local/bin/docker /usr/local/bin/docker
COPY --from=docker-cli /usr/local/libexec/docker/cli-plugins/ /usr/local/libexec/docker/cli-plugins/

WORKDIR /app
COPY --from=go-builder /app/wireops-worker ./wireops-worker

RUN mkdir -p /app/worker_pki \
    && chown -R appuser:appgroup /app \
    && chmod -R ug+rwX /app

USER appuser

ENTRYPOINT ["/app/wireops-worker"]
