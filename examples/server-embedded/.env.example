# Required — generate with: openssl rand -hex 32
SECRET_KEY=change_me_32_chars_minimum

# Public URL of the server (used for CORS and webhooks)
APP_URL=http://localhost:8090

# Host port to expose
PORT=8090

# Where PocketBase stores its data (databases, migrations)
PB_DATA_DIR=/data/pb_data

# Where git repositories are cloned
REPOS_WORKSPACE=/data/repos

# Set to true to disable the embedded agent
# WIREOPS_DISABLE_LOCAL_AGENT=false
