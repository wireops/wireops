# HTTP URL of the wireops server (used during bootstrap to obtain a certificate)
WIREOPS_SERVER=https://wireops.example.com

# mTLS URL of the wireops server (used for the command WebSocket channel)
WIREOPS_MTLS_SERVER=https://wireops.example.com:8443

# One-time bootstrap token — get this from the wireops admin panel (Agents → New Agent)
# Safe to remove after the first successful boot (certs are stored in the pki volume)
WIREOPS_BOOTSTRAP_TOKEN=

# Optional: override the name shown in the wireops UI
# AGENT_HOSTNAME=my-server-01
